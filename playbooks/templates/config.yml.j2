config_version: 3
projects_and_groups:
  "{{ target_scope }}":
    members:
      enforce_members: true
      users:
        admin_user_account:
          access_level: owner
        {% for user in temporary_access_list %}
        {{ user.name }}:
          access_level: {{ user.role }}
          expires_at: "{{ user.expiry }}"
        {% endfor %}